# Token bot dari Discord Developer Portal > Bot > Reset Token
DISCORD_TOKEN=isi_token_bot_disini

# Application ID / Client ID dari Discord Developer Portal > General Information
CLIENT_ID=isi_client_id_disini

# Guild/Server ID tempat bot akan dipakai (klik kanan nama server > Copy Server ID)
# Wajib aktifkan Developer Mode dulu di Discord (Settings > Advanced)
GUILD_ID=isi_guild_id_disini

# (Opsional) ID channel untuk log moderasi, kosongkan kalau tidak dipakai
MOD_LOG_CHANNEL_ID=
